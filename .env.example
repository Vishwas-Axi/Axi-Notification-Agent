# ---- Required ----
# Financial Modeling Prep API key (free tier is fine). https://site.financialmodelingprep.com/
# Used for: economic calendar, IPO calendar, treasury rates, index/FX/commodity quotes.
FMP_API_KEY=your_fmp_key_here

# OpenAI API key for alert refinement. https://platform.openai.com/
OPENAI_API_KEY=your_openai_key_here

# ---- Optional ----
# OpenAI model used to refine alert drafts (default: gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini

# Microsoft Teams Incoming Webhook URL (created via the "Workflows" app / Power Automate).
# Leave blank to disable the "Send to Teams" button.
TEAMS_WEBHOOK_URL=

# Default audience used in the AI drafting prompt.
ALERT_AUDIENCE=Axi dealing desks, relationship managers, affiliates and IB partners

# ---- Optional accuracy upgrades (NOT required — the app works without these) ----
# News is aggregated from free public RSS feeds (Yahoo Finance, CNBC, MarketWatch,
# Google News topic queries, the Federal Reserve) — these need NO key.
#
# FRED (Federal Reserve Economic Data) — free key, improves macro accuracy by using
# authoritative series instead of third-party calendar values. https://fred.stlouisfed.org/docs/api/api_key.html
# FRED_API_KEY=
#
# Marketaux — free 100 req/day, adds news sentiment + entity tagging. https://www.marketaux.com/
# MARKETAUX_API_KEY=
#
# Finnhub — free 60 req/min, richer company news + earnings/IPO data. https://finnhub.io/
# FINNHUB_API_KEY=
